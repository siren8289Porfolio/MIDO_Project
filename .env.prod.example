# EC2 /home/ubuntu/my-portfolio/.env
# remote-deploy.sh 가 없으면 deploy/ec2/.env.example 로 자동 생성합니다.
#
# GitHub Actions secrets (권장):
#   DB_USERNAME=postgres
#   DB_PASSWORD=<기존 DB 비밀번호>
#
# 수동 생성:
#   cp deploy/ec2/.env.example /home/ubuntu/my-portfolio/.env
#   nano /home/ubuntu/my-portfolio/.env

DB_USERNAME=postgres
DB_PASSWORD=change-me-strong-password
