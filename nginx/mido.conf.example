# Nginx reverse proxy (host nginx → mido-web + mido-app)
# Place under /etc/nginx/sites-available/ and symlink to sites-enabled.
#
# Prerequisites:
#   docker network create portfolio-network
#   mido-web, mido-app joined to portfolio-network (see docker-compose.prod.yml)

upstream mido_frontend {
    server mido-web:3000;
}

upstream mido_backend {
    server mido-app:8080;
}

server {
    listen 80;
    server_name mido.example.com;

    client_max_body_size 20M;

    # API → Spring Boot
    location /api/ {
        proxy_pass http://mido_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # UI → Next.js
    location / {
        proxy_pass http://mido_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
